# ============================================
# Acupunturista Master LMS - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ============================================
# PostgreSQL Database (Docker)
# ============================================
POSTGRES_USER=masterlms
POSTGRES_PASSWORD=masterlms_secret_2024
POSTGRES_DB=masterlms

# This is built automatically from the values above. 
# DO NOT change unless you know what you are doing.
DATABASE_URL=postgresql://masterlms:masterlms_secret_2024@postgres:5432/masterlms?schema=public

# ============================================
# Redis
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# Security
# ============================================
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET

# ============================================
# URLs
# ============================================
# The public URL where the frontend will be accessible (used for CORS)
FRONTEND_URL=http://localhost:3000
# The public URL where the backend API will be accessible
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================
# Cloudflare R2 Storage (for file uploads)
# ============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ============================================
# Bunny.net (for video hosting)
# ============================================
BUNNY_API_KEY=
BUNNY_LIBRARY_ID=
